#!/bin/bash

# VARIABLES.
backend="backend"
frontend="frontend"
executable="bin/wlnd"

# FONCTIONS.

# Couleurs.

# Affiche un texte selon une couleur ANSI.
colorize()
{
	echo "\e[$1m$2\e[0m"
}

# Affiche une information.
info()
{
	echo -e "[ $(colorize 34 "INFO") ]: $1"
}

# Affiche un succès.
success()
{
	echo -e "[ $(colorize 32 "OK") ]: $1"
}

# Affiche une erreur.
error()
{
	echo -e "[ $(colorize 31 "ERR") ]: $1" >&2

	[[ -n "$2" ]] && exit "$2" || exit 1
}

# Affiche un warning.
warning()
{
	echo -e "[ $(colorize 33 "WARN") ]: $1"
}

# LANCEMENT COMMANDE.
npx ts-node "./CommandDispatch.ts" "$@"
